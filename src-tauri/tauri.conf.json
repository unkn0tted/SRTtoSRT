{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Subtitle Duet",
  "version": "0.1.0",
  "identifier": "com.openai.subtitleduet",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Subtitle Duet",
        "width": 1460,
        "height": 960,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": ["icons/icon.png"],
    "targets": "all"
  }
}
